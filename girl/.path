export TIME_STYLE='long-iso'
export EDITOR='nvim'
export HISTSIZE=50000
export HISTFILESIZE=50000
export TS_SOCKET=/run/user/1000/tailscale/tailscaled.sock
export PNPM_HOME="${HOME}/.local/share/pnpm"

PATH="/home/linuxbrew/.linuxbrew/bin:${PATH}"
PATH="${PNPM_HOME}:${PATH}"
PATH="${HOME}/.local/bin:${PATH}"

FPATH=(/home/linuxbrew/.linuxbrew/share/zsh/site-functions $FPATH)
fpath=(/home/linuxbrew/.linuxbrew/share/zsh/site-functions $fpath)
fpath=$(brew --prefix)/share/zsh-completions:$fpath
fpath=(~/.zsh/completions $fpath)
fpath=(~/.zfunc $fpath)

export PATH
export fpath

# for lua SteamDeck 에서 mise 에 lua 를 설치하기 위한 설정
export PATH="/home/linuxbrew/.linuxbrew/opt/glibc/bin:/home/linuxbrew/.linuxbrew/opt/glibc/sbin:$PATH"
export LDFLAGS="-L/home/linuxbrew/.linuxbrew/opt/glibc/lib"
export CPPFLAGS="-I/home/linuxbrew/.linuxbrew/opt/glibc/include"
# for lua
