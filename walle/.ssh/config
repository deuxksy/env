Host *
  LogLevel error
  StrictHostKeyChecking no
  ServerAliveInterval 120
  UserKnownHostsFile /dev/null
  ForwardAgent yes
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_ed25519  # Ed25519를 기본으로 시도
  IdentityFile ~/.ssh/id_rsa      # 안 되면 RSA 시도
  Port 22
  IdentitiesOnly yes

